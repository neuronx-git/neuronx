          "id": "b1c",
          "type": "text",
          "content": {
            "richText": [
              {
                "type": "p",
                "children": [
                  {
                    "text": "I am your onboarding assistant. I will guide you through a few questions about your immigration goals so our RCIC team can prepare for your consultation."
                  }
                ]
              },
              {
                "type": "p",
                "children": [
                  {
                    "text": "This takes about 10 minutes. Your information is kept confidential and secure."
