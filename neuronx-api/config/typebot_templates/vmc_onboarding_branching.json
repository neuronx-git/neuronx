                "type": "p",
                "children": [
                  {
                    "text": "Your onboarding information has been submitted to our RCIC team. Here is what happens next:"
                  }
                ]
              },
              {
                "type": "p",
                "children": [
                  {
                    "text": "1. Our team reviews your information within 24 hours"
                  }
                ]
              },
              {
                "type": "p",
                "children": [
                  {
                    "text": "2. You will receive an email to book your consultation"
                  }
                ]
              },
              {
                "type": "p",
                "children": [
                  {
                    "text": "3. Our RCIC will prepare a personalized assessment"
                  }
                ]
              }
            ]
          }
